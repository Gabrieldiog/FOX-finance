# Banco de dados — Postgres gerenciado no Supabase (mesmo banco no dev e na produção).
# Pegue a connection string no painel do Supabase: Project Settings > Database > Connection string.
DATABASE_URL="postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres"

# Better Auth
# Gere um segredo forte com: openssl rand -base64 32
BETTER_AUTH_SECRET="troque-por-um-segredo-de-pelo-menos-16-chars"
BETTER_AUTH_URL="http://localhost:3000"

# Cadastro por convite: e-mails autorizados a criar conta (separados por vírgula).
ALLOWED_EMAILS="mae@exemplo.com,namorada@exemplo.com"
