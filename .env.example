# Banco de dados
# Local: suba o Postgres com `docker compose up -d` e use a URL abaixo.
# Produção: use o Neon (região São Paulo).
DATABASE_URL="postgresql://fox:fox@localhost:5432/fox_dev"

# Better Auth
# Gere um segredo forte com: openssl rand -base64 32
BETTER_AUTH_SECRET="troque-por-um-segredo-de-pelo-menos-16-chars"
BETTER_AUTH_URL="http://localhost:3000"
